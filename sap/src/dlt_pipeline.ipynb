# DLT pipeline

This Delta Live Tables (DLT) definition is executed using a pipeline defined in resources/sap_pipeline.yml.
#%%
# Import DLT and src/sap
import dlt
import sys
from pyspark.sql.functions import expr
from sap import main
#%%
@dlt.view
def taxi_raw():
  return main.get_taxis()

@dlt.table
def filtered_taxis():
  return dlt.read("taxi_raw").filter(expr("fare_amount < 30"))